// spec.md の「7. データモデル（概念設計）」に対応するPrismaスキーマ

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  employee
}

enum UserStatus {
  active
  terminated
}

enum GrantType {
  annual_auto
  special
}

enum LeaveUnit {
  full_day
  am_half
  pm_half
  hourly
}

enum LeaveRequestStatus {
  pending
  approved
  rejected
  cancelled
}

enum HolidayType {
  national_holiday
  company_day_off
}

/// 7.1 社員（User）
model User {
  id               String     @id @default(cuid())
  name             String
  email            String     @unique
  passwordHash     String     @map("password_hash")
  role             Role
  hireDate         DateTime   @map("hire_date") @db.Date
  terminationDate  DateTime?  @map("termination_date") @db.Date
  status           UserStatus @default(active)
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  leaveGrants      LeaveGrant[]
  leaveRequests    LeaveRequest[]   @relation("RequestsByUser")
  reviewedRequests LeaveRequest[]   @relation("RequestsReviewedBy")

  @@map("users")
}

/// 7.2 有給付与履歴（LeaveGrant）
model LeaveGrant {
  id                          String    @id @default(cuid())
  userId                      String    @map("user_id")
  grantType                   GrantType @default(annual_auto) @map("grant_type")
  grantedDate                 DateTime  @map("granted_date") @db.Date
  grantedDays                 Decimal   @map("granted_days") @db.Decimal(4, 1)
  /// 失効予定日（利用可能な最終日。付与日から2年後の前日）
  expireDate                  DateTime  @map("expire_date") @db.Date
  attendanceConfirmedAt       DateTime? @map("attendance_confirmed_at")
  attendanceConfirmedBy       String?   @map("attendance_confirmed_by")
  attendanceConfirmedSource   String?   @map("attendance_confirmed_source")
  createdAt                   DateTime  @default(now()) @map("created_at")

  user         User               @relation(fields: [userId], references: [id])
  consumptions LeaveConsumption[]

  // grant_type = annual_auto の場合のみ (user_id, granted_date) を一意とする運用ルール。
  // special は複数件を許容するため、部分ユニーク制約はアプリケーション層／DBマイグレーションで別途付与する。
  @@index([userId, expireDate])
  @@map("leave_grants")
}

/// 7.3 有給申請（LeaveRequest）
model LeaveRequest {
  id            String              @id @default(cuid())
  userId        String              @map("user_id")
  targetDate    DateTime            @map("target_date") @db.Date
  unit          LeaveUnit
  /// 時間単位年休(unit = hourly)の取得時間数(1〜8の整数)。hourly以外は常にnull
  hours         Int?                @map("hours")
  status        LeaveRequestStatus  @default(pending)
  requestedAt   DateTime            @default(now()) @map("requested_at")
  reviewedById  String?             @map("reviewed_by")
  reviewedAt    DateTime?           @map("reviewed_at")
  rejectReason  String?             @map("reject_reason")
  cancelledBy   String?             @map("cancelled_by")
  cancelledAt   DateTime?           @map("cancelled_at")
  cancelReason  String?             @map("cancel_reason")
  /// 期間一括申請(Phase 5)でまとめて作成された場合の識別子。単日申請は常にnull
  batchId       String?             @map("batch_id")

  user         User               @relation("RequestsByUser", fields: [userId], references: [id])
  reviewedBy   User?              @relation("RequestsReviewedBy", fields: [reviewedById], references: [id])
  consumptions LeaveConsumption[]

  // 同一日・同一区分の重複申請禁止（6章）はアプリケーション層でのバリデーションに加え、
  // (user_id, target_date, unit) の一意制約を pending/approved のみに適用する部分インデックスを別途検討する。
  // batch_idはこの一意制約には含めない(重複禁止とbatch所属は独立した関心事)。
  @@index([userId, targetDate])
  @@index([batchId])
  @@map("leave_requests")
}

/// 7.4 有給消化内訳（LeaveConsumption）
model LeaveConsumption {
  id             String    @id @default(cuid())
  leaveRequestId String    @map("leave_request_id")
  leaveGrantId   String    @map("leave_grant_id")
  /// 時間単位年休の消化(例: 1時間=0.125日)を保持するためDecimal(4,1)からDecimal(6,3)に拡張
  consumedDays   Decimal   @map("consumed_days") @db.Decimal(6, 3)
  cancelledAt    DateTime? @map("cancelled_at")

  leaveRequest LeaveRequest @relation(fields: [leaveRequestId], references: [id])
  leaveGrant   LeaveGrant   @relation(fields: [leaveGrantId], references: [id])

  @@map("leave_consumptions")
}

/// 会社カレンダー / 休日マスタ。祝日(national_holiday)と会社独自の休日(company_day_off)を
/// 同じテーブルで管理する。1日1件に限定(祝日と会社休日が同日の場合は手動登録時にエラー、
/// 内閣府データ取り込み時は既存のcompany_day_offを優先しスキップする)。
model Holiday {
  id        String      @id @default(cuid())
  date      DateTime    @map("date") @db.Date
  name      String
  type      HolidayType
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@unique([date])
  @@map("holidays")
}
