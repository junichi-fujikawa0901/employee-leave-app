# Prisma / PostgreSQL (docker-compose.yml のデフォルト値と一致させています)
DATABASE_URL="postgresql://leave_app:leave_app@localhost:5432/leave_app_dev?schema=public"

# NextAuth.js — `openssl rand -base64 32` などで生成した値に変更してください
AUTH_SECRET="change-me"

# Vercel Cron からの呼び出しを認証するための秘密値。`openssl rand -base64 32` などで生成してください
CRON_SECRET="change-me"
